@startuml SimuladorCampanha

skinparam classAttributeIconSize 0
skinparam style strictuml

' === Entidades principais ===

abstract class Unit {
  +int x, y
  +int hp, maxHp, attackDamage
  +String name
  +boolean isPlayer
  +boolean alive
  +double evasion
  --
  +boolean move(int newX, int newY, Grid grid)
  +void attack(Unit target, GameScreen gs)
  +int distanceTo(Unit other)
  +boolean isAdjacentTo(Unit other)
}

class Player extends Unit {
  -double fleeChance
  +boolean reachedDestination
  --
  +void takeTurn(Grid grid, List~Enemy~ enemies, GameScreen gs)
  -boolean fleeAndAdvance(Enemy threat, Grid grid, GameScreen gs)
  -boolean stepTowardDestination(Grid grid)
  -void moveRandom(Grid grid)
}

class Enemy extends Unit {
  -int detectionRadius
  -double aggressiveness
  --
  +void takeTurn(Grid grid, List~Player~ players, GameScreen gs)
  -void stepToward(Unit target, Grid grid)
  -void moveRandom(Grid grid)
}

class Grid {
  +int width, height
  +Tile[][] tiles
  +int destX, destY
  --
  +void setDestination(int x, int y)
  +boolean isValid(int x, int y)
}

class Tile {
  +boolean hasObstacle
  +boolean isDestination
  +Unit unit
  --
  +boolean isEmpty()
}

class Obstacle {
  +int x, y
  --
  +Obstacle(int x, int y, Grid grid)
}

' === Configuração ===

class MapConfig {
  +String missionTitle
  +int roundLimit
  +GridCfg grid
  +PosCfg destination
  +PosCfg spawn
  +List~PlayerCfg~ players
  +List~EnemyCfg~ enemies
  +List~ObstacleCfg~ obstacles
  --
  +{static} MapConfig load()
  +{static} MapConfig loadFile(String filename)
  +{static} MapConfig loadDefault()
}

class "MapConfig.PlayerCfg" as PlayerCfg {
  +int x, y
  +String name
  +int hp, damage
  +double evasion, fleeChance
}

class "MapConfig.EnemyCfg" as EnemyCfg {
  +int x, y
  +String name
  +int hp, damage
  +int detectionRadius
  +double aggressiveness
}

' === Gerenciamento de campanha ===

class MissionManager {
  -String campaignName
  -List~String~ mapFiles
  -int currentIndex
  +int victories, defeats, draws
  --
  +{static} MissionManager load()
  +MapConfig currentConfig()
  +void advance(MissionResult result)
  +boolean isFinished()
  +String scoreString()
  +String finalVerdict()
}

enum "MissionManager.MissionResult" as MissionResult {
  VICTORY
  DEFEAT
  DRAW
}

' === NOVA: Classe Resultado ===

class Resultado {
  +String missionTitle
  +MissionResult resultado
  +int roundsPlayed
  +int playersAlive
  +int playersAtDestination
  +int enemiesAlive
  +int totalPlayers
  +int totalEnemies
  +int runNumber
  --
  +String toSummary()
  +boolean isVictory()
  +boolean isDefeat()
  +boolean isDraw()
}

' === Telas ===

class GameScreen {
  -MainGame game
  -MissionManager missions
  -Grid grid
  -List~Player~ playerUnits
  -List~Enemy~ enemyUnits
  -List~Obstacle~ obstacles
  -int currentRound
  -int roundLimit
  -String gameOverMessage
  -MissionResult missionResult
  --
  +void show()
  +void render(float delta)
  +void log(String message)
  -void playerTurn()
  -void enemyTurn()
  -String checkGameOver()
  -void goToTransition()
}

class MissionTransitionScreen
class CampaignEndScreen
class MainGame

' === Relacionamentos ===

Unit "1" *-- "0..1" Tile : ocupa
Grid "1" *-- "many" Tile : contém
Obstacle --> Grid : marca hasObstacle
Player "many" --o GameScreen
Enemy  "many" --o GameScreen
Grid "1" --o GameScreen
MissionManager "1" --o GameScreen
MissionManager --> MapConfig : carrega
MissionManager "1" *-- "many" MissionResult
MissionManager --> Resultado : <>
MapConfig *-- PlayerCfg
MapConfig *-- EnemyCfg
MainGame --> GameScreen
GameScreen --> MissionTransitionScreen
MissionTransitionScreen --> GameScreen
MissionTransitionScreen --> CampaignEndScreen

@enduml